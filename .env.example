# URL Web App Google Apps Script (Deploy → Web App → Anyone)
# Wajib untuk email otomatis ke ardikamal1213@gmail.com + simpan spreadsheet/Drive
GAS_REGISTER_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Opsional: URL terpisah untuk upload (bisa sama dengan GAS_REGISTER_URL)
